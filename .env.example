# WorkSync Environment Variables
# Copy this file to .env and fill in your values

# Directus Configuration
DIRECTUS_URL=http://localhost:8055
DIRECTUS_ADMIN_EMAIL=admin@worksync.local
DIRECTUS_ADMIN_PASSWORD=admin_password_123

# Database Configuration
DATABASE_URL=postgresql://worksync:worksync_password@localhost:5432/worksync

# Next.js Public API URL (for browser-side requests)
NEXT_PUBLIC_API_URL=http://localhost:8055

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Directus Auth Keys (used in docker-compose.yml)
# KEY and SECRET should be random UUIDs
DIRECTUS_KEY=d1d9970c-1f23-4b37-9a7f-3a8c3e1b2c4d
DIRECTUS_SECRET=a3b5c7d9e1f2g4h6i8j0k2l4m6n8p0q2
