# AD Sync Agent — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.

# Port for the agent HTTP server
PORT=3100

# ── Active Directory Connection ───────────────────────────────
# LDAP URL of your Domain Controller
# Use ldap:// for plain LDAP (port 389) or ldaps:// for LDAP over SSL (port 636)
AD_URL=ldap://192.168.1.1

# Base DN for LDAP searches (e.g. your company's root)
AD_BASE_DN=DC=company,DC=local

# Service Account credentials — use a Read-Only account in AD
AD_BIND_DN=CN=svc-worksync,OU=ServiceAccounts,DC=company,DC=local
AD_BIND_PASSWORD=YourServiceAccountPasswordHere

# ── Security ─────────────────────────────────────────────────
# Pre-shared AES-256 key — must EXACTLY match AD_SHARED_KEY on the WorkSync (Hostinger) side
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SHARED_KEY=change_me_to_a_64_char_hex_string_generated_by_crypto

# Dedicated IP of your Hostinger VPS (only this IP is allowed to call this agent)
# Set to * to disable IP filtering (NOT recommended for production)
ALLOWED_IP=185.xx.xx.xx
